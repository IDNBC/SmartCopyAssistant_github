{
  "manifest_version": 3,
  "name": "Smart Copy Assistant",
  "description": "Save selected text automatically and manage clipboard history locally. No data is sent externally.",
  "version": "1.0",
  "permissions": ["storage", "sidePanel", "clipboardWrite"],
  "action": {
    "default_title": "コピーアシスタントを起動"
  },
  "icons": {
  "16": "icons/icon16.png",
  "48": "icons/icon48.png",
  "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "commands": {
  "_execute_side_panel": {
    "suggested_key": {
      "default": "Ctrl+Shift+Y"
    },
    "description": "サイドパネルを開く"
  }
}
}